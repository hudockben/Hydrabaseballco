# ---- Hydra Prospector environment variables ----
# Copy real values into Vercel (Project -> Settings -> Environment Variables).
# NEVER commit the real values.

# Neon Postgres connection string (use the "pooled" connection string from Neon).
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Password required to reach the /admin area.
ADMIN_PASSWORD="choose-a-strong-password"

# Long random string used to sign admin login cookies.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# Optional: free key from https://api.data.gov/signup/ for higher College
# Scorecard rate limits. Falls back to the shared DEMO_KEY if unset.
# SCORECARD_API_KEY=""
